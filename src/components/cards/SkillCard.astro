---
import Icon from "astro-icon";

export interface Props {
	title: string;
	icon: string
}
const { title, icon } = Astro.props;
---

<div
	class="flex flex-col bg-gray-100 rounded-lg border border-gray-200 p-4 h-32 w-full justify-center items-center text-center text-gray-700 space-y-4 transition-colors duration-200 ease-in-out hover:text-pink-600">
	<div>
		<Icon name={icon} class="h-8 w-8" />
	</div>
	<p class="uppercase font-bold tracking-tighter w-full truncate text-xs">{title}</p>
</div>