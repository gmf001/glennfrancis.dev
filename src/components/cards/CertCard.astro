---
export interface Props {
	title: string;
	body: string;
	href: string;
}
const { href, title, body } = Astro.props;
---

<a class="rounded-lg bg-darkSecondary shadow-sm border border-gray-700/50 px-6 py-8 group space-y-3" {href}
	target="_blank">
	<h2 class="font-bold uppercase text-base transition-opacity duration-200 ease-in-out group-hover:opacity-70">
		{title}
	</h2>
	<p class="text-xs font-medium text-gray-400">
		{body}
	</p>
</a>